{
  "extends": ["config:recommended", ":disableDependencyDashboard"],

  "baseBranchPatterns": ["dev"],

  "enabledManagers": ["cargo", "npm", "github-actions"],

  "labels": ["dependencies"],
  "dependencyDashboard": false,
  "rangeStrategy": "replace",
  "separateMajorMinor": true,
  "separateMultipleMajor": true,

  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**",
    "**/__tests__/**",
    "**/test/**",
    "**/tests/**",
    "**/__fixtures__/**",
    "shared/**"
  ],

  "packageRules": [
    {
      "description": "Use chore semantic commits for dependency updates",
      "matchPackageNames": ["*"],
      "semanticCommitType": "chore",
      "labels": ["dependencies"]
    },
    {
      "description": "Disable node/pnpm version updates",
      "matchPackageNames": ["node", "pnpm"],
      "matchDepTypes": ["engines", "packageManager"],
      "enabled": false
    },
    {
      "description": "Keep major updates separate and manual",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Group safe patch and minor updates",
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "safe dependency updates",
      "groupSlug": "safe-dependencies",
      "automerge": false
    },
    {
      "description": "Group Tauri npm packages and Rust crates together with high priority",
      "extends": ["monorepo:tauri"],
      "groupName": "tauri monorepo",
      "groupSlug": "tauri",
      "matchUpdateTypes": ["digest", "patch", "minor", "major"],
      "prPriority": 10,
      "minimumReleaseAge": null
    },

    {
      "description": "Group custom mihomo Tauri plugin API and Rust plugin together",
      "matchDepNames": ["tauri-plugin-mihomo-api", "tauri-plugin-mihomo"],
      "groupName": "tauri plugin mihomo",
      "groupSlug": "tauri-plugin-mihomo",
      "matchUpdateTypes": ["digest", "patch", "minor", "major"]
    },

    {
      "description": "Group React packages together",
      "matchDepNames": [
        "react",
        "react-dom",
        "react-router",
        "react-hook-form",
        "react-i18next",
        "react-error-boundary",
        "@types/react",
        "@types/react-dom"
      ],
      "groupName": "react packages",
      "groupSlug": "react"
    },

    {
      "description": "Group MUI packages together",
      "matchPackageNames": ["@mui/**", "@emotion/**"],
      "groupName": "mui packages",
      "groupSlug": "mui"
    },

    {
      "description": "Group TanStack packages together",
      "matchPackageNames": ["@tanstack/**"],
      "groupName": "tanstack packages",
      "groupSlug": "tanstack"
    },

    {
      "description": "Group GitHub Actions updates into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "github-actions"
    },

    {
      "description": "Group Rust workspace dependency updates",
      "matchManagers": ["cargo"],
      "groupName": "rust workspace dependencies",
      "groupSlug": "rust-workspace"
    }
  ],

  "postUpdateOptions": ["pnpmDedupe"],

  "ignoreDeps": ["criterion", "node", "pnpm"],

  "lockFileMaintenance": {
    "enabled": true,
    "description": "Refresh lockfiles and git dependency refs",
    "schedule": ["before 5am on monday"]
  }
}
