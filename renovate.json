{
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],

  "baseBranchPatterns": ["dev"],

  "enabledManagers": ["cargo", "npm", "github-actions"],

  "labels": ["dependencies"],

  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**",
    "**/__tests__/**",
    "**/test/**",
    "**/tests/**",
    "**/__fixtures__/**",
    "shared/**"
  ],

  "rangeStrategy": "replace",

  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["*"],
      "semanticCommitType": "chore"
    },
    {
      "description": "Disable node/pnpm version updates",
      "matchPackageNames": ["node", "pnpm"],
      "matchDepTypes": ["engines", "packageManager"],
      "enabled": false
    },

    {
      "description": "Prioritize Tauri updates",
      "extends": ["monorepo:tauri"],
      "groupName": "tauri monorepo",
      "groupSlug": "tauri",
      "matchUpdateTypes": ["digest", "patch", "minor", "major"],
      "prPriority": 10,
      "minimumReleaseAge": null
    },

    {
      "description": "Group custom mihomo Tauri plugin API and Rust plugin together",
      "matchDepNames": [
        "tauri-plugin-mihomo-api",
        "tauri-plugin-mihomo"
      ],
      "groupName": "tauri plugin mihomo",
      "groupSlug": "tauri-plugin-mihomo",
      "matchUpdateTypes": ["digest", "patch", "minor", "major"]
    },

    {
      "description": "Group React packages together",
      "matchDepNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "react packages",
      "groupSlug": "react"
    },

    {
      "description": "Group MUI packages together",
      "matchPackageNames": ["@mui/**", "@emotion/**"],
      "groupName": "mui packages",
      "groupSlug": "mui"
    },

    {
      "description": "Group TanStack packages together",
      "matchPackageNames": ["@tanstack/**"],
      "groupName": "tanstack packages",
      "groupSlug": "tanstack"
    },

    {
      "description": "Group GitHub Actions updates into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "github-actions"
    }
  ],

  "postUpdateOptions": ["pnpmDedupe"],

  "ignoreDeps": ["criterion"],

  "lockFileMaintenance": {
    "enabled": true,
    "description": "Refresh lockfiles and git dependency refs",
    "schedule": ["before 5am on monday"]
  }
}
